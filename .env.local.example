# mp3tuber 환경 변수 예시 — 이 파일을 `.env.local`로 복사해 값을 채운다.
# .env.local 은 절대 커밋하지 않는다(.gitignore 의 `.env.*` 로 무시됨).

# YouTube Data API v3 키 (search.list 호출용). 서버 전용 — `NEXT_PUBLIC_` 접두사 금지.
# 미설정 시 /api/search 는 CONFIG_ERROR(500)을 반환한다.
YOUTUBE_API_KEY=

# --- (선택) 변환 IP 차단 우회 — 호스팅 환경에서만 필요 ---
# 클라우드(Vercel 등) 데이터센터 IP는 YouTube 봇 차단에 걸려 변환이 실패할 수 있다.
# 로컬(집 IP)에서는 보통 불필요하다. 둘 다 서버 전용 — `NEXT_PUBLIC_` 금지.

# yt-dlp 트래픽을 우회시킬 프록시 URL(예: Cloudflare WARP, 레지덴셜 프록시). 값이 있을 때만 --proxy로 전달.
YTDLP_PROXY=

# YouTube 로그인 세션 cookies.txt "본문 전체"(Netscape 포맷). 값이 있을 때만 --cookies로 전달.
# 브라우저 확장(Get cookies.txt LOCALLY 등)으로 export 후 내용을 그대로 붙여넣는다.
# 비밀이므로 절대 커밋 금지. 만료되면 다시 export해 갱신한다.
YOUTUBE_COOKIES=
